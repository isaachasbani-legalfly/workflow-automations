{
  "name": "HubSpot Company Industry Categorization v3",
  "id": "iXrOSCZoFo9pwjsC",
  "nodes": [
    {
      "id": "1",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [100, 300],
      "parameters": {
        "rule": {
          "interval": [{"field": "cronExpression", "expression": "0 18 * * *"}]
        }
      }
    },
    {
      "id": "2",
      "name": "Get Uncategorized Companies",
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2.2,
      "position": [300, 300],
      "parameters": {
        "authentication": "appToken",
        "resource": "company",
        "operation": "getRecentlyCreatedUpdated",
        "returnAll": false,
        "limit": 50,
        "filters": {
          "filterGroupsUi": {
            "filterGroupsValues": [
              {
                "filtersUi": {
                  "filterValues": [
                    {
                      "propertyName": "industry_internal_sync",
                      "operator": "NOT_HAS_PROPERTY"
                    }
                  ]
                }
              }
            ]
          }
        },
        "additionalFields": {}
      },
      "credentials": {"hubspotAppToken": {"id": "5ww8XNGf4HTQu4UI", "name": "hubspot"}}
    },
    {
      "id": "3",
      "name": "Check Demo Form",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [500, 300],
      "parameters": {
        "conditions": {
          "options": {"version": 2, "leftValue": "", "caseSensitive": true, "typeValidation": "strict"},
          "combinator": "and",
          "conditions": [
            {
              "id": "demo-check",
              "operator": {"type": "string", "operation": "notEmpty"},
              "leftValue": "={{ $json.properties.industry__form____contact_sync }}",
              "rightValue": ""
            }
          ]
        }
      }
    },
    {
      "id": "4",
      "name": "Get Company Details",
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2.2,
      "position": [700, 400],
      "parameters": {
        "authentication": "appToken",
        "resource": "company",
        "operation": "get",
        "companyId": {"mode": "id", "value": "={{ $json.id }}"},
        "additionalFields": {
          "properties": ["name", "domain", "description", "about_us", "linkedin_company_page", "industry", "hs_ideal_customer_profile"]
        }
      },
      "credentials": {"hubspotAppToken": {"id": "5ww8XNGf4HTQu4UI", "name": "hubspot"}}
    },
    {
      "id": "5",
      "name": "Prepare Company Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [900, 400],
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {"id": "field1", "name": "companyId", "type": "string", "value": "={{ $json.id }}"},
            {"id": "field2", "name": "companyName", "type": "string", "value": "={{ $json.properties.name }}"},
            {"id": "field3", "name": "domain", "type": "string", "value": "={{ $json.properties.domain }}"},
            {"id": "field4", "name": "description", "type": "string", "value": "={{ $json.properties.description }}"},
            {"id": "field5", "name": "aboutUs", "type": "string", "value": "={{ $json.properties.about_us }}"},
            {"id": "field6", "name": "linkedinUrl", "type": "string", "value": "={{ $json.properties.linkedin_company_page }}"}
          ]
        }
      }
    },
    {
      "id": "6",
      "name": "Check Description Exists",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [1100, 400],
      "parameters": {
        "conditions": {
          "options": {"version": 2, "leftValue": "", "caseSensitive": true, "typeValidation": "strict"},
          "combinator": "and",
          "conditions": [
            {
              "id": "desc-check",
              "operator": {"type": "string", "operation": "notEmpty"},
              "leftValue": "={{ $json.description }}",
              "rightValue": ""
            }
          ]
        }
      }
    },
    {
      "id": "7",
      "name": "LinkedIn Enrichment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1300, 500],
      "parameters": {
        "url": "https://api.amplemarket.com/company/linkedin/enrichment",
        "method": "POST",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "amplemarket",
        "sendBody": true,
        "contentType": "json",
        "jsonBody": "={{ { \"linkedin_url\": $json.linkedinUrl } }}",
        "options": {}
      },
      "continueOnFail": true
    },
    {
      "id": "8",
      "name": "Check LinkedIn Success",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [1500, 500],
      "parameters": {
        "conditions": {
          "options": {"version": 2, "leftValue": "", "caseSensitive": true, "typeValidation": "strict"},
          "combinator": "and",
          "conditions": [
            {
              "id": "linkedin-check",
              "operator": {"type": "string", "operation": "notEmpty"},
              "leftValue": "={{ $json.description }}",
              "rightValue": ""
            }
          ]
        }
      }
    },
    {
      "id": "9",
      "name": "Website Scraping",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1700, 600],
      "parameters": {
        "url": "={{ 'https://' + $node['Prepare Company Data'].json.domain }}",
        "method": "GET",
        "authentication": "none",
        "options": {}
      },
      "continueOnFail": true
    },
    {
      "id": "10",
      "name": "Check Website Success",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [1900, 600],
      "parameters": {
        "conditions": {
          "options": {"version": 2, "leftValue": "", "caseSensitive": true, "typeValidation": "strict"},
          "combinator": "and",
          "conditions": [
            {
              "id": "website-check",
              "operator": {"type": "string", "operation": "contains"},
              "leftValue": "={{ $json }}",
              "rightValue": "description"
            }
          ]
        }
      }
    },
    {
      "id": "11",
      "name": "Online Research",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [2100, 700],
      "parameters": {
        "url": "https://serpapi.com/search",
        "method": "GET",
        "authentication": "none",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {"name": "q", "value": "={{ $node['Prepare Company Data'].json.companyName }} company information"},
            {"name": "api_key", "value": "YOUR_SERPAPI_KEY_HERE"},
            {"name": "num", "value": "3"},
            {"name": "engine", "value": "google"}
          ]
        },
        "options": {}
      },
      "continueOnFail": true
    }
  ],
