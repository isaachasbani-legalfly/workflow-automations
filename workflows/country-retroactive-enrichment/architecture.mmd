flowchart TD
    Start([Schedule Trigger\nDaily 01:00 London]) --> Init["Initialize State\n{after: null, allCompanies: [], maxPages: 1}"]
    Init --> Pass["Pass State"]
    Pass --> Fetch["Fetch Companies Page\nHubSpot Search API, limit: 100"]
    Fetch --> Accum["Accumulate Results\nmerge pages, extract cursor"]
    Accum --> More{"IF More Pages\nafter cursor not empty?"}
    More -->|"TRUE: loop back"| Pass
    More -->|"FALSE: done"| Split["Split All Companies"]
    Split --> Prepare["Prepare Company Data\ncompanyId, companyName, domain"]

    Prepare --> CheckDomain{"Check Has Domain\ndomain not empty?"}
    CheckDomain -->|"YES"| TLD["Extract TLD Country\n120+ country TLDs"]
    CheckDomain -->|"NO"| NameScan["Extract Country from Name\n130+ country names"]
    TLD --> CheckTLD{"TLD Resolved?"}
    CheckTLD -->|"YES"| Result
    CheckTLD -->|"NO"| NameScan
    NameScan --> CheckName{"Name Got Country?"}
    CheckName -->|"YES"| Result

    CheckName -->|"NO"| CheckDomainAmp{"Has Domain\nfor Amplemarket?"}
    CheckDomainAmp -->|"YES"| AmpDomain["Amplemarket Domain API\nGET /companies/find?domain="]
    CheckDomainAmp -->|"NO"| JinaSearch
    AmpDomain --> ParseAmp["Parse Amplemarket Country"]
    ParseAmp --> CheckAmp{"Got Country?"}
    CheckAmp -->|"YES"| Result

    CheckAmp -->|"NO"| JinaScrape["Jina Website Scrape\nGET r.jina.ai/{domain}\n10s timeout, batch: 2/5s"]
    JinaScrape --> CheckQuality["Check Website Quality\nCode: !error && !warning && len>200\noutputs _websiteOk"]
    CheckQuality --> CheckWebsite{"Website Content OK?"}
    CheckWebsite -->|"YES"| ExtractLinkedIn["Extract LinkedIn URL\nparse linkedin.com/company/\nfrom website + search"]
    CheckWebsite -->|"NO"| JinaSearch["DuckDuckGo Web Search\nGET r.jina.ai/duckduckgo.com/?q={name}\n+headquarters+country+location\nbatch: 2/5s"]
    JinaSearch --> ExtractLinkedIn
    ExtractLinkedIn --> CheckLinkedIn{"Has LinkedIn URL?"}
    CheckLinkedIn -->|"YES"| AmpLinkedIn["Amplemarket LinkedIn Lookup\nGET /companies/find?linkedin_url="]
    CheckLinkedIn -->|"NO"| PrepGemini
    AmpLinkedIn --> ParseAmpLinkedIn["Parse LinkedIn Amplemarket Country"]
    ParseAmpLinkedIn --> CheckAmpLinkedIn{"Got Country\nfrom LinkedIn?"}
    CheckAmpLinkedIn -->|"YES"| Result
    CheckAmpLinkedIn -->|"NO"| PrepGemini
    PrepGemini["Prepare Gemini Input\nstrict anti-hallucination prompt\n6000 char limit"] --> Gemini["Gemini Inference\ngemini-2.5-flash, temp 0.1\nNO tools, content-only"]
    Gemini --> ParseGemini["Parse Gemini Response\nJSON {country, evidence}"]
    ParseGemini --> CheckGemini{"Got Country?"}
    CheckGemini -->|"YES"| Result
    CheckGemini -->|"NO"| Unknown["Prepare Unknown\ncountry = 'Unknown'"]

    Result["Prepare Result\ncountry + enrichmentSource"] --> Snapshot
    Unknown --> Snapshot["Snapshot Data"]
    Snapshot --> UpdateHS["Update HubSpot\ncountry + countryenrichmentsource"]
    UpdateHS --> Restore["Restore Data"]
    Restore --> Format["Format Summary\nsingle Slack message\nuses $getWorkflowStaticData"]
    Format --> Slack["Send Slack\nchannel C0AG86U9927"]

