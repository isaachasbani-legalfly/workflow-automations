flowchart TD
    subgraph "Production Path"
        WH["Webhook: Deal Closed Won\nPOST /line-items-closed-won"] --> NW["Normalize Webhook Data\nExtract dealId from body"]
    end

    subgraph "Backfill Path"
        MT["Manual Trigger: Backfill"] --> SD["Search Closed Won Deals\nSales + Expansion pipelines"]
        SD --> ED["Extract Deal IDs\nNormalize to dealId items"]
    end

    NW --> GD["Get Deal + Associations\nGET deal props + line_items + companies"]
    ED --> GD

    GD --> EDD["Extract Deal Data\ndealId, closedate, currency,\ncompanyId, lineItemIds"]
    EDD --> BLI["Batch Read Line Items\nname, amount, qty, currency"]
    BLI --> FLI["Format Line Items\nName - Qty X - price - date"]
    FLI --> GC["Get Company Current Value\nproductpurchased property"]
    GC --> AP["Append & Prepare Update\nCombine existing + new"]
    AP --> UC["Update Company\nPATCH productpurchased"]

    style WH fill:#e1f5fe
