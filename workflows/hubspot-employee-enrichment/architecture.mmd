flowchart TD
    Start([Schedule Trigger\n02:01 daily London])

    Start --> InitState["Initialize State\n{after: null, allCompanies: []}"]
    InitState --> PassState["Pass State"]
    PassState --> FetchPage["Fetch Companies Page\nHubSpot API - createdate yesterday\nlimit 200 + cursor"]
    FetchPage --> Accumulate["Accumulate Results\nMerge pages"]
    Accumulate --> IfMore{IF Has More Pages\ncursor not empty?}
    IfMore -->|TRUE: loop back| PassState
    IfMore -->|FALSE: done| SplitAll["Split All Companies"]

    SplitAll --> Prepare["Prepare Company Data\ncompanyId, name, domain, linkedinUrl, existingEmployeeCount"]
    Prepare --> PrepClassify["Prepare Gemini Batch\nAll company names in single prompt"]
    PrepClassify --> GeminiClassify["Gemini Classify\ngemini-2.5-flash temp 0.2\nindependent vs subsidiary"]
    GeminiClassify --> ParseClassify["Parse Classification\nMerge results, replace branch domains"]
    ParseClassify --> Route{Check Needs Enrichment\nno count OR isSubsidiary?}

    Route -->|TRUE: needs enrichment| BuildBatch["Build Batch Request\nCollect companies + identifiers"]
    Route -->|FALSE: already good| Skip["Skip Independent\nnoOp"]

    BuildBatch --> SubmitBatch["Submit Batch\nPOST /enrichment-requests"]
    SubmitBatch --> InitPoll["Init Poll State\nrequestId, pollCount=0"]
    InitPoll --> Wait["Wait 15s"]
    Wait --> Poll["Poll Status\nGET /enrichment-requests/{id}"]
    Poll --> MergePoll["Merge Poll State"]
    MergePoll --> CheckComplete{Check Complete\nstatus=completed OR maxPolls?}
    CheckComplete -->|TRUE| ParseBatch["Parse Batch Results\nMatch by domain/linkedin"]
    CheckComplete -->|FALSE| IncCounter["Increment Counter\npollCount++"]
    IncCounter --> Wait

    ParseBatch --> CheckResolved{Check Resolved\nemployeeCount > 0?}
    CheckResolved -->|TRUE| PrepSource["Prepare Source\nAmplemarket or Amplemarket (parent: X)"]
    CheckResolved -->|FALSE| CheckDomain{Check Has Domain\ndomain not empty?}

    PrepSource --> PreservePreUpdate

    CheckDomain -->|TRUE| JinaScrape["Jina Scrape\nr.jina.ai/{domain}"]
    CheckDomain -->|FALSE| Default["Prepare Default\nemployeeCount=5, Estimated"]

    JinaScrape --> PrepEstimate["Prep Estimate Prompt\nClean content, build prompt"]
    PrepEstimate --> CheckContent{Check Has Content\ncontent > 50 chars?}
    CheckContent -->|TRUE| GeminiEstimate["Gemini Estimate\ngemini-2.5-flash temp 0.3"]
    CheckContent -->|FALSE| Default

    GeminiEstimate --> ParseEstimate["Parse Estimate\nExtract count, default 5"]
    ParseEstimate --> PreservePreUpdate
    Default --> PreservePreUpdate

    PreservePreUpdate["Preserve Pre-Update\nSnapshot all fields"]
    PreservePreUpdate --> UpdateHS["Update HubSpot\nnumberofemployees + source + is_subsidiary + parent"]
    UpdateHS --> PreserveResult["Preserve Result"]
    PreserveResult --> Aggregate["Aggregate Results"]
    Aggregate --> FormatSummary["Format Summary"]
    FormatSummary --> Slack["Send Slack\nChannel C0AG86U9927"]
