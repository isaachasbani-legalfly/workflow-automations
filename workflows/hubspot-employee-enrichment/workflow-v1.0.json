    {
      "id": "emp-format",
      "name": "Format Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3360, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Build summary message for Slack\nconst items = $input.all();\nlet enriched = 0;\nlet subsidiaries = 0;\nlet unresolved = 0;\nconst details = [];\n\nfor (const item of items) {\n  const d = item.json;\n  if (d.enrichmentSource === 'Unresolved') {\n    unresolved++;\n    details.push('\\u2753 ' + d.companyName + ' \\u2192 Unresolved');\n  } else if (d.enrichmentSource && d.enrichmentSource.startsWith('Amplemarket (parent:')) {\n    enriched++;\n    subsidiaries++;\n    details.push('\\ud83c\\udfe2 ' + d.companyName + ' \\u2192 ' + d.employeeCount + ' employees (' + d.enrichmentSource + ')');\n  } else {\n    enriched++;\n    details.push('\\u2705 ' + d.companyName + ' \\u2192 ' + d.employeeCount + ' employees');\n  }\n}\n\nconst total = items.length;\nconst summary = '*Employee Count Enrichment Summary*\\n'\n  + 'Total processed: ' + total + '\\n'\n  + 'Enriched: ' + enriched + (subsidiaries > 0 ? ' (' + subsidiaries + ' subsidiaries adjusted)' : '') + '\\n'\n  + 'Unresolved: ' + unresolved + '\\n\\n'\n  + '*Details:*\\n'\n  + details.slice(0, 50).join('\\n');\n\nreturn [{ json: { message: summary } }];"
      }
    },
    {
      "id": "emp-slack",
      "name": "Send Slack Summary",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.4,
      "position": [3600, 300],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "C0AFSAD1E5A",
          "mode": "id"
        },
        "text": "={{ $json.message }}",
        "otherOptions": {}
      },
      "credentials": {
        "slackApi": {
          "id": "lYs0WHzWk4c7z9Kk",
          "name": "Slack"
        }
      }
    }
  ],
