          "customPropertiesUi": {
            "customPropertiesValues": [
              {
                "property": "numberofemployees",
                "value": "={{ $json.employeeCount }}"
              },
              {
                "property": "number-employees-enrichment-source",
                "value": "={{ $json.enrichmentSource }}"
              }
            ]
          }
        }
      },
      "credentials": {
        "hubspotAppToken": {
          "id": "5ww8XNGf4HTQu4UI",
