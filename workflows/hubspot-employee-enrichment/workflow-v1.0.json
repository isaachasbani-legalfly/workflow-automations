    {
      "id": "emp-parse-amp",
      "name": "Parse Amplemarket",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1920, 300],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse Amplemarket response - extract employee count\nconst data = $json;\nlet companyData = data;\n\n// If the response is wrapped\nif (data.data) companyData = data.data;\nif (data.company) companyData = data.company;\n\n// Try various field names for employee count\nconst employeeCount = companyData.employee_count\n  || companyData.employees\n  || companyData.size\n  || companyData.number_of_employees\n  || companyData.headcount\n  || 0;\n\n// Carry forward company identifiers\nconst companyId = $('Prepare Company Data').item.json.companyId;\nconst companyName = $('Prepare Company Data').item.json.companyName;\nconst domain = $('Prepare Company Data').item.json.domain;\n\nreturn {\n  json: {\n    companyId,\n    companyName,\n    domain,\n    employeeCount: parseInt(employeeCount) || 0,\n    amplemarketRaw: companyData\n  }\n};"
      }
    },
    {
      "id": "emp-check-count",
      "name": "Check Got Count",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [2160, 300],
      "parameters": {
        "conditions": {
          "options": {
            "version": 3,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "c3",
              "operator": {
                "type": "number",
                "operation": "gt"
              },
              "leftValue": "={{ $json.employeeCount }}",
              "rightValue": 0
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "emp-prep-gemini",
      "name": "Prepare Gemini Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 200],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Build Gemini prompt for branch/subsidiary detection\nconst companyName = $json.companyName;\nconst domain = $json.domain;\nconst count = $json.employeeCount;\n\nconst prompt = 'You are analyzing a company to determine its correct employee count.\\n\\n'\n  + 'Company: ' + companyName + '\\n'\n  + 'Domain: ' + domain + '\\n'\n  + 'Amplemarket reported employee count: ' + count + '\\n\\n'\n  + 'Tasks:\\n'\n  + '1. Is this company a local branch, subsidiary, or regional office of a larger parent?\\n'\n  + '   - \"KPMG Spain\" is a branch of KPMG\\n'\n  + '   - \"Google UK\" is a branch of Alphabet/Google\\n'\n  + '   - Look for country names, city names, or region indicators in the company name\\n'\n  + '2. If it IS a branch: estimate the GLOBAL employee count of the parent organization\\n'\n  + '3. If it is NOT a branch: return the Amplemarket count as-is\\n\\n'\n  + 'Return ONLY valid JSON (no markdown, no explanation):\\n'\n  + '{\"employeeCount\": <number>, \"isSubsidiary\": true/false, \"parentCompany\": \"<name or null>\"}';\n\nreturn {\n  json: {\n    companyId: $json.companyId,\n    companyName,\n    domain,\n    originalCount: count,\n    prompt\n  }\n};"
      }
    },
    {
      "id": "emp-gemini",
      "name": "Gemini Branch Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2640, 200],
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googlePalmApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ contents: [{ parts: [{ text: $json.prompt }] }], generationConfig: { temperature: 0.1 } }) }}",
        "options": {
          "timeout": 30000
        }
      },
      "credentials": {
        "googlePalmApi": {
          "id": "QnUjlFnc4gypgplL",
          "name": "Gemini"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "emp-parse-gemini",
      "name": "Parse Gemini",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2880, 200],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse Gemini response and prepare final result\nconst response = $json;\nconst companyId = $('Prepare Gemini Prompt').item.json.companyId;\nconst companyName = $('Prepare Gemini Prompt').item.json.companyName;\nconst originalCount = $('Prepare Gemini Prompt').item.json.originalCount;\n\nlet geminiResult = {};\ntry {\n  const text = response.candidates?.[0]?.content?.parts?.[0]?.text || '';\n  const cleaned = text.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  geminiResult = JSON.parse(cleaned);\n} catch (e) {\n  // If parsing fails, use original Amplemarket data\n  geminiResult = {\n    employeeCount: originalCount,\n    isSubsidiary: false,\n    parentCompany: null\n  };\n}\n\nconst finalCount = geminiResult.employeeCount || originalCount;\nconst isSubsidiary = geminiResult.isSubsidiary || false;\nconst parentCompany = geminiResult.parentCompany || null;\n\nlet enrichmentSource = 'Amplemarket';\nif (isSubsidiary && parentCompany) {\n  enrichmentSource = 'Amplemarket (parent: ' + parentCompany + ')';\n}\n\nreturn {\n  json: {\n    companyId,\n    companyName,\n    employeeCount: finalCount,\n    enrichmentSource\n  }\n};"
      }
    },
    {
      "id": "emp-unknown",
      "name": "Prepare Unknown",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2640, 600],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Mark as unresolved - no employee data available\nconst companyId = $('Prepare Company Data').item.json.companyId;\nconst companyName = $('Prepare Company Data').item.json.companyName;\n\nreturn {\n  json: {\n    companyId,\n    companyName,\n    employeeCount: '',\n    enrichmentSource: 'Unresolved'\n  }\n};"
      }
    },
    {
      "id": "emp-update-hs",
      "name": "Update HubSpot",
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2.2,
      "position": [3120, 300],
      "parameters": {
        "authentication": "appToken",
        "resource": "company",
        "operation": "update",
        "companyId": {
          "mode": "id",
          "value": "={{ $json.companyId }}"
